# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=app
DB_PASSWORD=secret
DB_NAME=foodapp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=foodapp-group

# ── Auth service (:8080) ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
AUTH_PORT=8080

# ── Orders service (:8081) ────────────────────────────────────────────────────
ORDERS_PORT=8081

# ── Deliveries service (:8082) ────────────────────────────────────────────────
DELIVERIES_PORT=8082

# ── Restaurants service (:8083) ───────────────────────────────────────────────
RESTAURANTS_PORT=8083

# ── Payments service (:8084) ──────────────────────────────────────────────────
PAYMENTS_PORT=8084
PAYMENT_GATEWAY_KEY=dummy-key
PAYMENT_GATEWAY_URL=https://sandbox.payment-gateway.example.com

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_PORT=80

# ── Observability (optional) ─────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
