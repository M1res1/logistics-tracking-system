{
  "title": "App Overview",
  "uid": "app-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests / sec (all services)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) by (job)",
          "legendFormat": "{{job}} errors"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (job, le)) * 1000",
          "legendFormat": "{{job}} p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Requests (1 min)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[1m]))",
          "legendFormat": "Total"
        }
      ]
    }
  ]
}
